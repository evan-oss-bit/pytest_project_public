# Backend runtime
PYTEST_TOOL_SECRET_KEY=change-me
# Keep empty to use flaskProject/db/database.db automatically.
PYTEST_TOOL_DATABASE_URL=
PYTEST_TOOL_REDIS_HOST=127.0.0.1
PYTEST_TOOL_REDIS_PORT=6379
PYTEST_TOOL_REDIS_DB=3

# Email
PYTEST_TOOL_EMAIL_HOST=
PYTEST_TOOL_EMAIL_TOKEN=
PYTEST_TOOL_EMAIL_SMTP=smtp.qq.com

# Optional MySQL / Celery
PYTEST_TOOL_MYSQL_URL=mysql+pymysql://root:password@127.0.0.1:3306/database?charset=utf8mb4
PYTEST_TOOL_MYSQL_HOST=127.0.0.1
PYTEST_TOOL_MYSQL_PORT=3306
PYTEST_TOOL_MYSQL_USER=root
PYTEST_TOOL_MYSQL_PASSWORD=password
PYTEST_TOOL_CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
PYTEST_TOOL_CELERY_RESULT_BACKEND=redis://localhost:6379/15

# Optional legacy integrations
PYTEST_TOOL_IMAGE_REDIS_HOST=127.0.0.1
PYTEST_TOOL_IMAGE_REDIS_PASSWORD=
PYTEST_TOOL_IMAGE_REDIS_PORT=6379
PYTEST_TOOL_FILE_SERVER=127.0.0.1
